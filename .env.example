DATABASE_URL=postgresql+psycopg://studyrag:studyrag@localhost:55433/studyrag
STUDYRAG_TEST_DATABASE_URL=postgresql+psycopg://studyrag:studyrag@localhost:55433/studyrag_test
JWT_SECRET=change-me-in-production-use-at-least-32-bytes
PORT=8000
HOST=0.0.0.0

# API/runtime behavior.
STUDYRAG_CORS_ORIGINS=http://localhost:5173
STUDYRAG_RETRIEVAL_TOP_K=4
STUDYRAG_MESSAGE_RATE_LIMIT=30/minute
STUDYRAG_SKIP_MIGRATIONS=false

# Optional OpenAI-compatible answer generation. If unset, StudyRAG uses the
# deterministic extractive generator used by the local tests.
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=

# Optional real Ragas LLM-as-judge metrics. If unset, eval/runner.py keeps
# faithfulness/relevancy labeled as deterministic local proxies.
RAGAS_EVALUATOR_API_KEY=
RAGAS_EVALUATOR_MODEL=
RAGAS_EVALUATOR_BASE_URL=
RAGAS_EVALUATOR_EMBEDDING_MODEL=text-embedding-3-small

# Phase 3 object storage. Use local for development/tests, or s3 for Cloudflare R2/S3.
STUDYRAG_STORAGE_BACKEND=local
STUDYRAG_LOCAL_STORAGE_DIR=.studyrag_storage
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# Public demo mode for deployed reviewers.
STUDYRAG_DEMO_ENABLED=false
STUDYRAG_DEMO_USER_EMAIL=demo@studyrag.local
STUDYRAG_SAMPLE_COURSE_NAME=StudyRAG Sample Course
STUDYRAG_SAMPLE_COURSE_STORAGE_URL=local://eval/study-rag-sample-course-notes.txt
STUDYRAG_SEED_SAMPLE_COURSE_ON_STARTUP=false
STUDYRAG_ATTACH_SAMPLE_COURSE_ON_REGISTER=false

# Vercel client build variable.
VITE_API_BASE_URL=http://localhost:8000
